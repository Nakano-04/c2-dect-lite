<Window x:Class="C2Dect.Lite.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:local="clr-namespace:C2Dect.Lite.Converters"
        Title="C2-DECT Lite - Operator Console" Height="900" Width="1400"
        WindowStartupLocation="CenterScreen"
        Background="#0c0e14"
        Loaded="Window_Loaded"
        FontFamily="Segoe UI">
    <Window.Resources>
        <local:StringToBrushConverter x:Key="ColorToBrush"/>

        <!-- Nav button -->
        <Style x:Key="NavBtn" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="#6a7080"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Height" Value="34"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="HorizontalContentAlignment" Value="Left"/>
            <Setter Property="Padding" Value="16,0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border" Background="{TemplateBinding Background}"
                                Padding="{TemplateBinding Padding}" CornerRadius="4" Margin="8,1">
                            <ContentPresenter HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                              VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Background" Value="#161a24"/>
                                <Setter Property="Foreground" Value="#e0e0e0"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Action button -->
        <Style x:Key="ActionBtn" TargetType="Button">
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Height" Value="32"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Padding" Value="14,0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border" Background="{TemplateBinding Background}"
                                CornerRadius="4" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Opacity" Value="0.85"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Quick command pill -->
        <Style x:Key="QuickBtn" TargetType="Button">
            <Setter Property="Height" Value="28"/>
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="Padding" Value="10,0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="FontFamily" Value="Consolas"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border" Background="{TemplateBinding Background}"
                                CornerRadius="4"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="1" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Opacity" Value="0.8"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="200"/>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="300"/>
        </Grid.ColumnDefinitions>

        <!-- ===== SIDEBAR ===== -->
        <Border Grid.Column="0" Background="#0c0e14" BorderBrush="#1a1e28"
                BorderThickness="0,0,1,0">
            <DockPanel>
                <!-- Logo -->
                <StackPanel DockPanel.Dock="Top" Margin="20,20,20,20">
                    <TextBlock Text="C2-DECT LITE" FontSize="22" FontWeight="Bold"
                               Foreground="#00e676" FontFamily="Consolas"/>
                    <StackPanel Orientation="Horizontal" Margin="0,8,0,0">
                        <Ellipse Width="7" Height="7" Fill="#00c853" Margin="0,0,6,0"
                                 VerticalAlignment="Center"/>
                        <TextBlock Text="{Binding CurrentOperator, StringFormat='Operator: {0}'}"
                                   FontSize="11" Foreground="#4a5060"/>
                    </StackPanel>
                </StackPanel>

                <!-- Navigation -->
                <StackPanel DockPanel.Dock="Top">
                    <TextBlock Text="NAVIGATION" FontSize="10" Foreground="#3a3f50"
                               FontWeight="Bold" Margin="20,4,0,6"/>
                    <Button Content="  Sessions" Command="{Binding NavigateToSessionsCommand}"
                            Style="{StaticResource NavBtn}" FontWeight="SemiBold"
                            Foreground="#e0e0e0"/>
                    <Button Content="  Loot" Command="{Binding NavigateToLootCommand}"
                            Style="{StaticResource NavBtn}"/>

                    <TextBlock Text="INFO" FontSize="10" Foreground="#3a3f50"
                               FontWeight="Bold" Margin="20,16,0,6"/>
                    <TextBlock Text="  Open Source C2" Style="{StaticResource NavBtn}"
                               Foreground="#4a5060" IsHitTestVisible="False"/>
                    <TextBlock Text="  v1.0" Style="{StaticResource NavBtn}"
                               Foreground="#4a5060" IsHitTestVisible="False"/>
                </StackPanel>

                <!-- Bottom status -->
                <Border DockPanel.Dock="Bottom" Background="#080a10" Padding="16,12"
                        BorderBrush="#1a1e28" BorderThickness="0,1,0,0">
                    <StackPanel>
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="Active: " FontSize="11" Foreground="#4a5060"/>
                            <TextBlock Text="{Binding ActiveSessions, Mode=OneWay}"
                                       FontSize="11" Foreground="#00c853" FontWeight="Bold"/>
                            <TextBlock Text="  |  Total: " FontSize="11" Foreground="#4a5060"/>
                            <TextBlock Text="{Binding TotalSessions, Mode=OneWay}"
                                       FontSize="11" Foreground="#d4a017"/>
                        </StackPanel>
                        <TextBlock Text="{Binding StatusText}" FontSize="10"
                                   Foreground="#2a2e3a" TextTrimming="CharacterEllipsis"
                                   Margin="0,4,0,0"/>
                    </StackPanel>
                </Border>
            </DockPanel>
        </Border>

        <!-- ===== MAIN AREA ===== -->
        <Grid Grid.Column="1">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="260"/>
            </Grid.RowDefinitions>

            <!-- Toolbar -->
            <Border Grid.Row="0" Background="#0f1118" Padding="12,8"
                    BorderBrush="#1a1e28" BorderThickness="0,0,0,1">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <Button Grid.Column="0" Content="  Refresh"
                            Command="{Binding RefreshAllCommand}"
                            Style="{StaticResource ActionBtn}" Background="#161a24"
                            Foreground="#6a7080" BorderBrush="#252a36" BorderThickness="1"
                            Margin="0,0,10,0"/>
                    <TextBlock Grid.Column="1"
                               Text="{Binding SelectedSession.DisplayName, FallbackValue='Select a session'}"
                               VerticalAlignment="Center" Foreground="#e0e0e0"
                               FontSize="13" FontWeight="SemiBold" Margin="8,0,0,0"/>
                    <TextBlock Grid.Column="2" Text="{Binding StatusText}"
                               VerticalAlignment="Center" Foreground="#3a3f50"
                               FontSize="11"/>
                </Grid>
            </Border>

            <!-- Sessions Table -->
            <Border Grid.Row="1" Background="#0c0e14">
                <DataGrid ItemsSource="{Binding Sessions}"
                          SelectedItem="{Binding SelectedSession}"
                          AutoGenerateColumns="False" IsReadOnly="True"
                          Background="#0c0e14" Foreground="#c0c8d8"
                          BorderThickness="0" RowBackground="#0c0e14"
                          AlternatingRowBackground="#11141c"
                          HeadersVisibility="Column" SelectionMode="Single"
                          CanUserAddRows="False"
                          GridLinesVisibility="Horizontal"
                          HorizontalGridLinesBrush="#1a1e28">
                    <DataGrid.ColumnHeaderStyle>
                        <Style TargetType="DataGridColumnHeader">
                            <Setter Property="Background" Value="#080a10"/>
                            <Setter Property="Foreground" Value="#5a6070"/>
                            <Setter Property="FontWeight" Value="SemiBold"/>
                            <Setter Property="FontSize" Value="11"/>
                            <Setter Property="Padding" Value="10,8"/>
                            <Setter Property="BorderBrush" Value="#1a1e28"/>
                            <Setter Property="BorderThickness" Value="0,0,1,1"/>
                        </Style>
                    </DataGrid.ColumnHeaderStyle>
                    <DataGrid.Columns>
                        <DataGridTextColumn Header=" " Binding="{Binding StatusIcon}" Width="35"/>
                        <DataGridTextColumn Header="ID" Binding="{Binding Id}" Width="110"/>
                        <DataGridTextColumn Header="Host" Binding="{Binding Hostname}" Width="150"/>
                        <DataGridTextColumn Header="User" Binding="{Binding Username}" Width="130"/>
                        <DataGridTextColumn Header="OS" Binding="{Binding OS}" Width="70"/>
                        <DataGridTextColumn Header="PID" Binding="{Binding PID}" Width="55"/>
                        <DataGridTextColumn Header="Sleep"
                                            Binding="{Binding SleepSec, StringFormat='{}{0}s'}"
                                            Width="55"/>
                        <DataGridTextColumn Header="Last Check-in"
                                            Binding="{Binding LastCheckIn, StringFormat='{}{0:HH:mm:ss}'}"
                                            Width="90"/>
                    </DataGrid.Columns>
                </DataGrid>
            </Border>

            <!-- Console -->
            <Border Grid.Row="2" Background="#080a10" BorderBrush="#1a1e28"
                    BorderThickness="0,1,0,0">
                <DockPanel>
                    <!-- Input bar -->
                    <Border DockPanel.Dock="Bottom" Background="#0f1118" Padding="8,6"
                            BorderBrush="#1a1e28" BorderThickness="0,1,0,0">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>

                            <TextBox x:Name="CommandInput" Grid.Column="0"
                                     Background="Transparent" Foreground="#00e676"
                                     FontFamily="Consolas" FontSize="13"
                                     BorderThickness="0" Padding="8,4"
                                     KeyDown="CommandInput_KeyDown"
                                     CaretBrush="#00e676"/>
                            <Button Grid.Column="1" Content=" Send" Height="30"
                                    Click="SendCommand_Click"
                                    Style="{StaticResource ActionBtn}"
                                    Background="#0a2e1a" Foreground="#00e676"
                                    Margin="4,0,4,0"/>
                            <Button Grid.Column="2" Content=" ?" Height="30" Width="30"
                                    Click="HelpButton_Click"
                                    Style="{StaticResource ActionBtn}"
                                    Background="#161a24" Foreground="#6a7080"
                                    Margin="0,0,0,0" FontWeight="Bold"/>
                        </Grid>
                    </Border>

                    <!-- Console output -->
                    <ScrollViewer x:Name="ConsoleScroller"
                                  VerticalScrollBarVisibility="Auto"
                                  Background="#080a10">
                        <ItemsControl ItemsSource="{Binding ConsoleOutput}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <TextBlock Padding="10,2" FontFamily="Consolas"
                                               FontSize="12"
                                               Foreground="{Binding Color, Converter={StaticResource ColorToBrush}}"
                                               Text="{Binding Content}"
                                               TextWrapping="Wrap"/>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </ScrollViewer>
                </DockPanel>
            </Border>
        </Grid>

        <!-- ===== RIGHT PANEL ===== -->
        <Border Grid.Column="2" Background="#0c0e14" BorderBrush="#1a1e28"
                BorderThickness="1,0,0,0">
            <ScrollViewer VerticalScrollBarVisibility="Auto">
                <StackPanel Margin="16,16,16,16">

                    <!-- Quick Commands -->
                    <TextBlock Text="QUICK COMMANDS" FontSize="10" Foreground="#3a3f50"
                               FontWeight="Bold" Margin="0,0,0,8"/>
                    <WrapPanel Margin="0,0,0,16">
                        <Button Content="sysinfo" Margin="0,0,4,4"
                                Style="{StaticResource QuickBtn}" Background="#1a1508"
                                Foreground="#d4a017" BorderBrush="#3a3010"
                                Click="QuickCommand_Click"/>
                        <Button Content="netinfo" Margin="0,0,4,4"
                                Style="{StaticResource QuickBtn}" Background="#1a1508"
                                Foreground="#d4a017" BorderBrush="#3a3010"
                                Click="QuickCommand_Click"/>
                        <Button Content="ps" Margin="0,0,4,4"
                                Style="{StaticResource QuickBtn}" Background="#1a1508"
                                Foreground="#d4a017" BorderBrush="#3a3010"
                                Click="QuickCommand_Click"/>
                        <Button Content="connections" Margin="0,0,4,4"
                                Style="{StaticResource QuickBtn}" Background="#1a1508"
                                Foreground="#d4a017" BorderBrush="#3a3010"
                                Click="QuickCommand_Click"/>
                        <Button Content="services" Margin="0,0,4,4"
                                Style="{StaticResource QuickBtn}" Background="#1a1508"
                                Foreground="#d4a017" BorderBrush="#3a3010"
                                Click="QuickCommand_Click"/>
                        <Button Content="env" Margin="0,0,4,4"
                                Style="{StaticResource QuickBtn}" Background="#1a1508"
                                Foreground="#d4a017" BorderBrush="#3a3010"
                                Click="QuickCommand_Click"/>
                    </WrapPanel>

                    <!-- File Operations -->
                    <TextBlock Text="FILE OPERATIONS" FontSize="10" Foreground="#3a3f50"
                               FontWeight="Bold" Margin="0,0,0,8"/>
                    <WrapPanel Margin="0,0,0,16">
                        <Button Content="dir C:\" Margin="0,0,4,4"
                                Style="{StaticResource QuickBtn}" Background="#0d2617"
                                Foreground="#00c853" BorderBrush="#145028"
                                Click="QuickCommand_Click"/>
                        <Button Content="dir Desktop" Margin="0,0,4,4"
                                Style="{StaticResource QuickBtn}" Background="#0d2617"
                                Foreground="#00c853" BorderBrush="#145028"
                                Click="QuickCommand_Click"/>
                        <Button Content="dir Downloads" Margin="0,0,4,4"
                                Style="{StaticResource QuickBtn}" Background="#0d2617"
                                Foreground="#00c853" BorderBrush="#145028"
                                Click="QuickCommand_Click"/>
                        <Button Content="find C:\\*.txt" Margin="0,0,4,4"
                                Style="{StaticResource QuickBtn}" Background="#0d2617"
                                Foreground="#00c853" BorderBrush="#145028"
                                Click="QuickCommand_Click"/>
                    </WrapPanel>

                    <!-- Agent Control -->
                    <TextBlock Text="AGENT CONTROL" FontSize="10" Foreground="#3a3f50"
                               FontWeight="Bold" Margin="0,0,0,8"/>
                    <WrapPanel Margin="0,0,0,16">
                        <Button Content="sleep 5" Margin="0,0,4,4"
                                Style="{StaticResource QuickBtn}" Background="#1a0d0d"
                                Foreground="#ff5252" BorderBrush="#3a1a1a"
                                Click="QuickCommand_Click"/>
                        <Button Content="sleep 30" Margin="0,0,4,4"
                                Style="{StaticResource QuickBtn}" Background="#1a0d0d"
                                Foreground="#ff5252" BorderBrush="#3a1a1a"
                                Click="QuickCommand_Click"/>
                        <Button Content="exit" Margin="0,0,4,4"
                                Style="{StaticResource QuickBtn}" Background="#1a0d0d"
                                Foreground="#ff5252" BorderBrush="#3a1a1a"
                                Click="QuickCommand_Click"/>
                    </WrapPanel>

                    <Border Height="1" Background="#1a1e28" Margin="0,0,0,16"/>

                    <!-- Session Info -->
                    <TextBlock Text="SESSION INFO" FontSize="10" Foreground="#3a3f50"
                               FontWeight="Bold" Margin="0,0,0,8"/>
                    <Grid Margin="0,0,0,16">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="60"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="22"/><RowDefinition Height="22"/>
                            <RowDefinition Height="22"/><RowDefinition Height="22"/>
                            <RowDefinition Height="22"/><RowDefinition Height="22"/>
                        </Grid.RowDefinitions>

                        <TextBlock Grid.Row="0" Text="Host:" Foreground="#4a5060" FontSize="11"/>
                        <TextBlock Grid.Row="0" Grid.Column="1"
                                   Text="{Binding SelectedSession.Hostname, FallbackValue='-'}"
                                   Foreground="#c0c8d8" FontSize="11"/>

                        <TextBlock Grid.Row="1" Text="User:" Foreground="#4a5060" FontSize="11"/>
                        <TextBlock Grid.Row="1" Grid.Column="1"
                                   Text="{Binding SelectedSession.Username, FallbackValue='-'}"
                                   Foreground="#c0c8d8" FontSize="11"/>

                        <TextBlock Grid.Row="2" Text="OS:" Foreground="#4a5060" FontSize="11"/>
                        <TextBlock Grid.Row="2" Grid.Column="1"
                                   Text="{Binding SelectedSession.OS, FallbackValue='-'}"
                                   Foreground="#c0c8d8" FontSize="11"/>

                        <TextBlock Grid.Row="3" Text="PID:" Foreground="#4a5060" FontSize="11"/>
                        <TextBlock Grid.Row="3" Grid.Column="1"
                                   Text="{Binding SelectedSession.PID, FallbackValue='-'}"
                                   Foreground="#c0c8d8" FontSize="11"/>

                        <TextBlock Grid.Row="4" Text="IP:" Foreground="#4a5060" FontSize="11"/>
                        <TextBlock Grid.Row="4" Grid.Column="1"
                                   Text="{Binding SelectedSession.InternalIp, FallbackValue='-'}"
                                   Foreground="#c0c8d8" FontSize="11"/>

                        <TextBlock Grid.Row="5" Text="Sleep:" Foreground="#4a5060" FontSize="11"/>
                        <TextBlock Grid.Row="5" Grid.Column="1"
                                   Text="{Binding SelectedSession.SleepSec, StringFormat='{}{0}s', FallbackValue='-'}"
                                   Foreground="#c0c8d8" FontSize="11"/>
                    </Grid>

                    <Border Height="1" Background="#1a1e28" Margin="0,0,0,16"/>

                    <!-- Tasks -->
                    <TextBlock Text="TASKS" FontSize="10" Foreground="#3a3f50"
                               FontWeight="Bold" Margin="0,0,0,8"/>
                    <ListView ItemsSource="{Binding Tasks}" MaxHeight="300"
                              Background="Transparent" Foreground="#c0c8d8"
                              BorderThickness="0">
                        <ListView.ItemContainerStyle>
                            <Style TargetType="ListViewItem">
                                <Setter Property="Background" Value="Transparent"/>
                                <Setter Property="Padding" Value="0,4"/>
                            </Style>
                        </ListView.ItemContainerStyle>
                        <ListView.ItemTemplate>
                            <DataTemplate>
                                <StackPanel Margin="0,2">
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="{Binding Command}" FontWeight="Bold"
                                                   FontSize="11" Foreground="#e0e0e0"/>
                                        <TextBlock Text="{Binding CreatedAt, StringFormat='{}{0:HH:mm:ss}'}"
                                                   Foreground="#2a2e3a" FontSize="10"
                                                   Margin="8,0,0,0"/>
                                    </StackPanel>
                                    <TextBlock Text="{Binding Result}" Foreground="#00e676"
                                               FontFamily="Consolas" FontSize="10"
                                               TextTrimming="CharacterEllipsis"
                                               MaxWidth="280"/>
                                </StackPanel>
                            </DataTemplate>
                        </ListView.ItemTemplate>
                    </ListView>
                </StackPanel>
            </ScrollViewer>
        </Border>
    </Grid>
</Window>
