<Window x:Class="C2Dect.Lite.Views.LoginWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="C2-DECT Lite Login" Height="480" Width="420"
        WindowStartupLocation="CenterScreen"
        Background="#0c0e14"
        ResizeMode="NoResize"
        FontFamily="Segoe UI">
    <Window.Resources>
        <Style x:Key="SectionLabel" TargetType="TextBlock">
            <Setter Property="Foreground" Value="#5a6070"/>
            <Setter Property="FontSize" Value="10"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Margin" Value="0,0,0,6"/>
        </Style>

        <Style x:Key="LoginInput" TargetType="TextBox">
            <Setter Property="Background" Value="#12151c"/>
            <Setter Property="Foreground" Value="#e0e0e0"/>
            <Setter Property="BorderBrush" Value="#1e2330"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="FontFamily" Value="Consolas"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Padding" Value="12,10"/>
            <Setter Property="CaretBrush" Value="#00e676"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TextBox">
                        <Border x:Name="bd" Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="6" Padding="{TemplateBinding Padding}">
                            <ScrollViewer x:Name="PART_ContentHost"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsFocused" Value="True">
                                <Setter TargetName="bd" Property="BorderBrush" Value="#00e67680"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Grid Grid.Row="0" Margin="40,40,40,0">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="12"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="8"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="8"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="8"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- Logo -->
            <TextBlock Grid.Row="0" Text="C2-DECT LITE" FontSize="34" FontWeight="Bold"
                       Foreground="#00e676" HorizontalAlignment="Center"
                       FontFamily="Consolas"/>

            <!-- Decorative line -->
            <Border Grid.Row="2" Height="1" Background="#1e2330"
                    HorizontalAlignment="Center" Width="200"/>

            <!-- Subtitle -->
            <TextBlock Grid.Row="3" Text="Open Source C2 Framework" FontSize="12"
                       Foreground="#5a6070" HorizontalAlignment="Center"
                       Margin="0,0,0,4"/>

            <!-- Server URL -->
            <StackPanel Grid.Row="5">
                <TextBlock Text="SERVER" Style="{StaticResource SectionLabel}"
                           Foreground="#5a6070" FontSize="10" FontWeight="SemiBold"
                           Margin="0,0,0,6"/>
                <TextBox x:Name="ServerBox" Style="{StaticResource LoginInput}"
                         Text="http://127.0.0.1:8443"/>
            </StackPanel>

            <!-- Username -->
            <StackPanel Grid.Row="7">
                <TextBlock Text="USERNAME" Style="{StaticResource SectionLabel}"
                           Foreground="#5a6070" FontSize="10" FontWeight="SemiBold"
                           Margin="0,0,0,6"/>
                <TextBox x:Name="UsernameBox" Style="{StaticResource LoginInput}"/>
            </StackPanel>

            <!-- Password -->
            <StackPanel Grid.Row="9">
                <TextBlock Text="PASSWORD" Style="{StaticResource SectionLabel}"
                           Foreground="#5a6070" FontSize="10" FontWeight="SemiBold"
                           Margin="0,0,0,6"/>
                <Border Background="#12151c" BorderBrush="#1e2330"
                        BorderThickness="1" CornerRadius="6">
                    <PasswordBox x:Name="PasswordBox" BorderThickness="0"
                                 Foreground="#e0e0e0" Padding="12,10" FontSize="14"
                                 FontFamily="Consolas"/>
                </Border>
            </StackPanel>

            <!-- Login Button -->
            <Button Grid.Row="10" Content="LOGIN" HorizontalAlignment="Stretch"
                    Height="46" Click="LoginButton_Click" Margin="0,4,0,0"
                    FontSize="14" FontWeight="Bold" FontFamily="Consolas"
                    Cursor="Hand">
                <Button.Template>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="bd" Background="#0a2e1a"
                                BorderBrush="#00e67640" BorderThickness="1"
                                CornerRadius="6">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="bd" Property="Background" Value="#0d3a22"/>
                                <Setter TargetName="bd" Property="BorderBrush" Value="#00e676"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="bd" Property="Background" Value="#082010"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Button.Template>
                <Button.Foreground>
                    <SolidColorBrush Color="#00e676"/>
                </Button.Foreground>
            </Button>

            <!-- Status -->
            <TextBlock Grid.Row="11" x:Name="StatusText" HorizontalAlignment="Center"
                       Foreground="#ff5252" FontSize="12" Margin="0,10,0,0"/>
        </Grid>

        <!-- Footer -->
        <Border Grid.Row="1" Background="#0f1118" Padding="0,10"
                BorderBrush="#1a1e28" BorderThickness="0,1,0,0">
            <TextBlock Text="C2-DECT Lite v1.0 - Open Source" HorizontalAlignment="Center"
                       Foreground="#2a2e3a" FontSize="10" FontFamily="Consolas"/>
        </Border>
    </Grid>
</Window>
